#!/bin/bash
# speaker вҖ” Professional intelligence mesh. 818M people. 3.7M companies. SQL-native.
# 10 tables. Enter anywhere. more queries = more signal.

set -e

# --- Config ---
VERSION="3.0.0"
ROOT_URL="${ROOT_URL:-https://raw.githubusercontent.com/migsterrrrr/speaker/master}"
REPO_URL="${REPO_URL:-$ROOT_URL/cli}"
SKILL_URL="${SKILL_URL:-$ROOT_URL/SKILL.md}"
API_URL="${API_URL:-https://api.speaker.sh}"
CONFIG_DIR="${CONFIG_DIR:-$HOME/.speaker}"
CONFIG_FILE="$CONFIG_DIR/config"
SCHEMA_DIR="$CONFIG_DIR/tables"

# --- Version check (non-blocking, background) ---
check_version() {
    local latest
    latest=$(curl -sf --max-time 5 -H "Cache-Control: no-cache" "$REPO_URL/VERSION" 2>/dev/null)
    if [[ -n "$latest" && "$latest" != "$VERSION" ]]; then
        echo "" >&2
        echo "  вҡЎ Update available: $VERSION вҶ’ $latest" >&2
        echo "     Run: speaker update" >&2
        echo "" >&2
    fi
}

cmd_update() {
    local target tmp_target new_ver
    target=$(command -v speaker 2>/dev/null || true)
    if [[ -z "$target" ]]; then
        echo "Error: speaker is not on PATH. Re-run the installer." >&2
        exit 1
    fi
    if [[ ! -w "$(dirname "$target")" ]]; then
        echo "Error: no write access to $(dirname "$target"). Re-run the installer with a user-writable BINDIR or PREFIX." >&2
        exit 1
    fi

    echo "Updating speaker CLI..."
    tmp_target=$(mktemp)
    if ! curl --fail --show-error --silent --location "$REPO_URL/speaker" -o "$tmp_target"; then
        rm -f "$tmp_target"
        echo "Error: failed to download updated CLI." >&2
        exit 1
    fi
    chmod +x "$tmp_target"

    mkdir -p "$CONFIG_DIR"
    if ! curl --fail --show-error --silent --location "$SKILL_URL" -o "$CONFIG_DIR/SKILL.md"; then
        rm -f "$tmp_target"
        echo "Error: failed to refresh $CONFIG_DIR/SKILL.md" >&2
        exit 1
    fi
    if ! sync_schema_docs; then
        rm -f "$tmp_target"
        echo "Error: failed to refresh local schema docs" >&2
        exit 1
    fi

    mv "$tmp_target" "$target"
    new_ver=$(grep '^VERSION=' "$target" | cut -d'"' -f2)
    echo "вң“ Updated to v${new_ver}"
}

# --- Helpers ---
json_escape() {
    local s="${1//\\/\\\\}"
    echo "${s//\"/\\\"}"
}

get_key() {
    if [[ -f "$CONFIG_FILE" ]]; then
        cat "$CONFIG_FILE"
    else
        echo ""
    fi
}

require_key() {
    local key=$(get_key)
    if [[ -z "$key" ]]; then
        echo "Not logged in. Run 'speaker signup' or 'speaker login' first." >&2
        exit 1
    fi
    echo "$key"
}

check_auth() {
    if [[ ! -f "$CONFIG_FILE" ]] || [[ -z "$(cat "$CONFIG_FILE")" ]]; then
        echo "Not logged in. Run 'speaker signup' or 'speaker login' first."
        exit 1
    fi
}

schema_artifacts() {
    cat << 'EOF'
_mesh.yaml|tables/_mesh.yaml
all.yaml|tables/all.yaml
people.main.yaml|tables/people/main.yaml
people.career.yaml|tables/people/career.yaml
people.education.yaml|tables/people/education.yaml
people.contact.yaml|tables/people/contact.yaml
people.repos.yaml|tables/people/repos.yaml
companies.main.yaml|tables/companies/main.yaml
companies.jobs.yaml|tables/companies/jobs.yaml
companies.news.yaml|tables/companies/news.yaml
web.links.yaml|tables/web/links.yaml
web.pages.yaml|tables/web/pages.yaml
EOF
}

sync_schema_docs() {
    local src dst
    mkdir -p "$SCHEMA_DIR"
    while IFS='|' read -r dst src; do
        [[ -z "$dst" ]] && continue
        if ! curl --fail --show-error --silent --location "$ROOT_URL/$src" -o "$SCHEMA_DIR/$dst"; then
            return 1
        fi
    done < <(schema_artifacts)
}

schema_path_for() {
    local table="$1"
    case "$table" in
        people.main|people.career|people.education|people.contact|people.repos|companies.main|companies.jobs|companies.news|web.links|web.pages)
            echo "$SCHEMA_DIR/$table.yaml"
            ;;
        *)
            return 1
            ;;
    esac
}

ensure_schema_docs() {
    if [[ ! -d "$SCHEMA_DIR" ]]; then
        echo "Error: local schema docs not found. Run 'speaker update'." >&2
        exit 1
    fi
}

