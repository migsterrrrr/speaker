#!/bin/bash
# speaker вҖ” SQL-native professional intelligence for agents.
# 825M people. 26M companies. 16 public tables. more queries = more signal.

set -e

# --- Config ---
VERSION="3.1.1"
ROOT_URL="${ROOT_URL:-https://raw.githubusercontent.com/migsterrrrr/speaker/master}"
REPO_URL="${REPO_URL:-$ROOT_URL/cli}"
SKILL_URL="${SKILL_URL:-$ROOT_URL/SKILL.md}"
API_URL="${API_URL:-https://api.speaker.sh}"
CONFIG_DIR="${CONFIG_DIR:-$HOME/.speaker}"
CONFIG_FILE="$CONFIG_DIR/config"
SCHEMA_DIR="$CONFIG_DIR/tables"

# --- Version check (non-blocking, background) ---
check_version() {
    local latest
    latest=$(curl -sf --max-time 5 -H "Cache-Control: no-cache" "$REPO_URL/VERSION" 2>/dev/null)
    if [[ -n "$latest" && "$latest" != "$VERSION" ]]; then
        echo "" >&2
        echo "  вҡЎ Update available: $VERSION вҶ’ $latest" >&2
        echo "     Run: speaker update" >&2
        echo "" >&2
    fi
}

cmd_update() {
    local target tmp_target new_ver
    target=$(command -v speaker 2>/dev/null || true)
    if [[ -z "$target" ]]; then
        echo "Error: speaker is not on PATH. Re-run the installer." >&2
        exit 1
    fi
    if [[ ! -w "$(dirname "$target")" ]]; then
        echo "Error: no write access to $(dirname "$target"). Re-run the installer with a user-writable BINDIR or PREFIX." >&2
        exit 1
    fi

    echo "Updating speaker CLI..."
    tmp_target=$(mktemp)
    if ! curl --fail --show-error --silent --location "$REPO_URL/speaker" -o "$tmp_target"; then
        rm -f "$tmp_target"
        echo "Error: failed to download updated CLI." >&2
        exit 1
    fi
    chmod +x "$tmp_target"

    mkdir -p "$CONFIG_DIR"
    if ! curl --fail --show-error --silent --location "$SKILL_URL" -o "$CONFIG_DIR/SKILL.md"; then
        rm -f "$tmp_target"
        echo "Error: failed to refresh $CONFIG_DIR/SKILL.md" >&2
        exit 1
    fi
    if ! sync_schema_docs; then
        rm -f "$tmp_target"
        echo "Error: failed to refresh local schema docs" >&2
        exit 1
    fi

    mv "$tmp_target" "$target"
    new_ver=$(grep '^VERSION=' "$target" | cut -d'"' -f2)
    echo "вң“ Updated to v${new_ver}"
}

# --- Helpers ---
json_escape() {
    local s="${1//\\/\\\\}"
    echo "${s//\"/\\\"}"
}

get_key() {
    if [[ -f "$CONFIG_FILE" ]]; then
        cat "$CONFIG_FILE"
    else
        echo ""
    fi
}

require_key() {
    local key=$(get_key)
    if [[ -z "$key" ]]; then
        echo "Not logged in. Run 'speaker signup' or 'speaker login' first." >&2
        exit 1
    fi
    echo "$key"
}

check_auth() {
    if [[ ! -f "$CONFIG_FILE" ]] || [[ -z "$(cat "$CONFIG_FILE")" ]]; then
        echo "Not logged in. Run 'speaker signup' or 'speaker login' first."
        exit 1
    fi
}

schema_artifacts() {
    cat << 'EOF'
_mesh.yaml|mesh.yaml
people.nucleus.yaml|tables/people/nucleus.yaml
people.contacts.yaml|tables/people/contacts.yaml
people.roles_history.yaml|tables/people/roles_history.yaml
people.education.yaml|tables/people/education.yaml
people.repos.yaml|tables/people/repos.yaml
companies.nucleus.yaml|tables/companies/nucleus.yaml
companies.identifiers.yaml|tables/companies/identifiers.yaml
companies.metrics.yaml|tables/companies/metrics.yaml
companies.industry_keywords.yaml|tables/companies/industry_keywords.yaml
companies.jobs.yaml|tables/companies/jobs.yaml
companies.posts.yaml|tables/companies/posts.yaml
companies.competitors.yaml|tables/companies/competitors.yaml
companies.funding_rounds.yaml|tables/companies/funding_rounds.yaml
companies.web_outlinks.yaml|tables/companies/web_outlinks.yaml
web.domain_entity_bridge.yaml|tables/web/domain_entity_bridge.yaml
web.pages.yaml|tables/web/pages.yaml
EOF
}

sync_schema_docs() {
    local src dst
    mkdir -p "$SCHEMA_DIR"
    rm -f "$SCHEMA_DIR"/*.yaml
    while IFS='|' read -r dst src; do
        [[ -z "$dst" ]] && continue
        if ! curl --fail --show-error --silent --location "$ROOT_URL/$src" -o "$SCHEMA_DIR/$dst"; then
            return 1
        fi
    done < <(schema_artifacts)
}

schema_path_for() {
    local table="$1"
    case "$table" in
        people.nucleus|people.contacts|people.roles_history|people.education|people.repos|companies.nucleus|companies.identifiers|companies.metrics|companies.industry_keywords|companies.jobs|companies.posts|companies.competitors|companies.funding_rounds|companies.web_outlinks|web.domain_entity_bridge|web.pages)
            echo "$SCHEMA_DIR/$table.yaml"
            ;;
        *)
            return 1
            ;;
    esac
}

ensure_schema_docs() {
    if [[ ! -d "$SCHEMA_DIR" ]] || [[ ! -f "$SCHEMA_DIR/_mesh.yaml" ]]; then
        echo "Refreshing local schema docs..." >&2
        if ! sync_schema_docs; then
            echo "Error: local schema docs not found and refresh failed. Run 'speaker update'." >&2
            exit 1
        fi
    fi
}

refresh_schema_docs_once() {
    local refreshed_var="$1"
    if [[ "${!refreshed_var}" -eq 0 ]]; then
        echo "Refreshing local schema docs..." >&2
        if ! sync_schema_docs; then
            echo "Error: failed to refresh local schema docs. Run 'speaker update'." >&2
            exit 1
        fi
        printf -v "$refreshed_var" 1
    fi
}

