#!/bin/bash
# speaker — Professional intelligence mesh. 818M people. 3.7M companies. SQL-native.
# 10 tables. Enter anywhere. more queries = more signal.

set -e

# --- Config ---
VERSION="3.0.0"
REPO_URL="https://raw.githubusercontent.com/migsterrrrr/speaker-cli/master/cli"
API_URL="https://api.speaker.sh"
CONFIG_DIR="$HOME/.speaker"
CONFIG_FILE="$CONFIG_DIR/config"

# --- Version check (non-blocking, background) ---
check_version() {
    local latest
    latest=$(curl -sf --max-time 5 -H "Cache-Control: no-cache" "$REPO_URL/VERSION" 2>/dev/null)
    if [[ -n "$latest" && "$latest" != "$VERSION" ]]; then
        echo "" >&2
        echo "  ⚡ Update available: $VERSION → $latest" >&2
        echo "     Run: speaker update" >&2
        echo "" >&2
    fi
}

cmd_update() {
    echo "Updating speaker CLI..."
    curl --fail --show-error --silent --location "$REPO_URL/speaker" -o /usr/local/bin/speaker
    chmod +x /usr/local/bin/speaker
    mkdir -p "$CONFIG_DIR"
    if ! curl --fail --show-error --silent --location "https://raw.githubusercontent.com/migsterrrrr/speaker-cli/master/SKILL.md" -o "$CONFIG_DIR/SKILL.md"; then
        echo "Warning: updated CLI, but failed to refresh $CONFIG_DIR/SKILL.md" >&2
    fi
    local new_ver=$(grep '^VERSION=' /usr/local/bin/speaker | cut -d'"' -f2)
    echo "✓ Updated to v${new_ver}"
}

# --- Helpers ---
json_escape() {
    local s="${1//\\/\\\\}"
    echo "${s//\"/\\\"}"
}

get_key() {
    if [[ -f "$CONFIG_FILE" ]]; then
        cat "$CONFIG_FILE"
    else
        echo ""
    fi
}

require_key() {
    local key=$(get_key)
    if [[ -z "$key" ]]; then
        echo "Not logged in. Run 'speaker signup' or 'speaker login' first." >&2
        exit 1
    fi
    echo "$key"
}

check_auth() {
    if [[ ! -f "$CONFIG_FILE" ]] || [[ -z "$(cat "$CONFIG_FILE")" ]]; then
        echo "Not logged in. Run 'speaker signup' or 'speaker login' first."
        exit 1
    fi
}

# --- Commands ---
cmd_signup() {
    local email="$1"
    local invite_code="$2"

    # Interactive if args not provided
    if [[ -z "$email" ]]; then
        echo "Create a new account"
        echo ""
        read -p "Email: " email
    fi
    if [[ -z "$invite_code" ]]; then
        read -p "Invite code: " invite_code
    fi

    if [[ -z "$email" || -z "$invite_code" ]]; then
        echo "Error: email and invite code required"
        exit 1
    fi

    local resp
    if ! resp=$(curl --fail --show-error --silent "$API_URL/signup" \
        -H "Content-Type: application/json" \
        -d "{\"email\":\"$(json_escape "$email")\",\"invite_code\":\"$(json_escape "$invite_code")\"}" 2>&1); then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        echo "Error: ${detail:-signup failed}"
        exit 1
    fi

    local key=$(echo "$resp" | grep -o '"api_key":"[^"]*"' | cut -d'"' -f4)
    if [[ -z "$key" ]]; then
        echo "Error: unexpected response"
        exit 1
    fi

    mkdir -p "$CONFIG_DIR"
    echo "$key" > "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"

    cat << 'WELCOME'

    ┌─────────────────────────────────────────────────────────────────┐
    │                                                                 │
    │   ███████╗██████╗ ███████╗ █████╗ ██╗  ██╗███████╗██████╗       │
    │   ██╔════╝██╔══██╗██╔════╝██╔══██╗██║ ██╔╝██╔════╝██╔══██╗      │
    │   ███████╗██████╔╝█████╗  ███████║█████╔╝ █████╗  ██████╔╝      │
    │   ╚════██║██╔═══╝ ██╔══╝  ██╔══██║██╔═██╗ ██╔══╝  ██╔══██╗      │
    │   ███████║██║     ███████╗██║  ██║██║  ██╗███████╗██║  ██║      │
    │   ╚══════╝╚═╝     ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝      │
    │                                                  speaker.sh     │
    │                                                                 │
    │   818M people. 3.7M companies. 10 tables. The mesh.             │
    │                                                                 │
    │   Your agent should read: ~/.speaker/SKILL.md                   │
    │   Quick start: speaker help                                     │
    │                                                                 │
    └─────────────────────────────────────────────────────────────────┘
WELCOME
}

cmd_login() {
    # Accept key directly: speaker login sk-abc123
    if [[ -n "$1" ]]; then
        # Validate the key
        if ! curl --fail --show-error --silent "$API_URL/health" -H "X-API-Key: $1" >/dev/null 2>&1; then
            echo "Error: invalid API key or service unavailable"
            exit 1
        fi
        mkdir -p "$CONFIG_DIR"
        echo "$1" > "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"
        echo "✓ API key saved. You're in."
        return
    fi

    echo "Log in to your account"
    echo ""
    read -p "Email: " email
    read -sp "Password: " password
    echo ""

    local resp
    if ! resp=$(curl --fail --show-error --silent "$API_URL/login" \
        -H "Content-Type: application/json" \
        -d "{\"email\":\"$(json_escape "$email")\",\"password\":\"$(json_escape "$password")\"}" 2>&1); then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        echo "Error: ${detail:-invalid email or password}"
        exit 1
    fi

    local key=$(echo "$resp" | grep -o '"api_key":"[^"]*"' | cut -d'"' -f4)
    if [[ -z "$key" ]]; then
        echo "Error: unexpected response"
        exit 1
    fi

    mkdir -p "$CONFIG_DIR"
    echo "$key" > "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    echo "✓ Logged in. API key saved."
}

cmd_status() {
    read -p "Email: " email

    local resp
    if ! resp=$(curl --fail --show-error --silent "$API_URL/status" \
        -H "Content-Type: application/json" \
        -d "{\"email\":\"$(json_escape "$email")\"}" 2>&1); then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        echo "${detail:-Could not check status}"
        exit 1
    fi

    local status=$(echo "$resp" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

    case "$status" in
        approved)
            echo "✓ Account approved."
            if [[ -f "$CONFIG_FILE" ]]; then
                echo "  API key is already saved. Run 'speaker query' to get started."
            else
                echo "  Run 'speaker login' to set your API key."
            fi
            ;;
        pending)
            echo "⏳ Account is still pending approval. Check back later."
            ;;
        *)
            echo "No account found for this email. Run 'speaker signup' to create one."
            ;;
    esac
}

cmd_logout() {
    rm -f "$CONFIG_FILE"
    echo "✓ Logged out. API key removed."
}

cmd_query() {
    check_auth
    local key=$(get_key)
    local sql="$1"

    if [[ -z "$sql" ]]; then
        echo "Usage: speaker query \"SELECT ...\""
        exit 1
    fi

    # Hint on first query of session
    local session_marker="$CONFIG_DIR/.session_$$"
    if [[ ! -f "$CONFIG_DIR/.session_hint" ]] || [[ $(find "$CONFIG_DIR/.session_hint" -mmin +60 2>/dev/null) ]]; then
        echo "💡 Tip: Read ~/.speaker/SKILL.md — the mesh diagram + explore loop." >&2
        echo "" >&2
        touch "$CONFIG_DIR/.session_hint"
    fi

    local resp http_code
    if ! resp=$(curl --silent --show-error --location -w "\n%{http_code}" --max-time 60 "$API_URL/query" \
        -H "X-API-Key: $key" \
        -d "$sql" 2>&1); then
        echo "Error: query request failed: $resp" >&2
        exit 1
    fi

    http_code=$(echo "$resp" | tail -1)
    resp=$(echo "$resp" | sed '$d')

    if [[ "$http_code" != "200" ]]; then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        if [[ "$http_code" == "429" ]]; then
            echo "Error: Rate limit hit. Wait a moment and try again." >&2
        elif [[ "$http_code" == "000" ]]; then
            echo "Error: Could not connect to server. Check your internet connection." >&2
        elif [[ -n "$detail" ]]; then
            echo "Error: $detail" >&2
        else
            echo "Error: query failed (HTTP $http_code)" >&2
        fi
        exit 1
    fi

    if [[ -z "$resp" ]] || [[ "$resp" == "" ]]; then
        echo "No results. Try DESCRIBE database.table to see columns." >&2
        return
    fi

    # Format output
    if [[ -t 1 ]]; then
        # Terminal: pretty print
        echo "$resp" | while IFS= read -r line; do
            echo "$line" | python3 -m json.tool 2>/dev/null || echo "$line"
        done
    else
        # Piped: raw JSON lines
        echo "$resp"
    fi
}

cmd_count() {
    check_auth
    local key=$(get_key)
    local resp
    if ! resp=$(curl --fail --show-error --silent "$API_URL/query" \
        -H "X-API-Key: $key" \
        -d "SELECT formatReadableQuantity(count()) as people FROM people.main" 2>&1); then
        echo "Error: could not get count: $resp" >&2
        exit 1
    fi
    local count=$(echo "$resp" | grep -o '"people":"[^"]*"' | cut -d'"' -f4)
    echo "${count:-Error: could not get count}"
}

cmd_schema() {
    check_auth
    cat << 'SCHEMA'

    THE MESH

         ⚡  📡  🎓  📋
          ╲  │  │  ╱
           ◉ people ◉
               ║
            🕸️─╬─📄
               ║
           ◉ companies ◉
          ╱  │  ╲
        📰  💼  📋

    👤 people.main          818M    Identity, role, skills, education, scores
    📋 people.career        974M    Full role history
    🎓 people.education     333M    Schools, degrees, fields of study
    📡 people.contact       863M    LinkedIn, email, Twitter, GitHub, website
    ⚡ people.repos          40M    GitHub repositories

