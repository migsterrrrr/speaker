cmd_login() {
    # Accept key directly: speaker login sk-abc123
    if [[ -n "$1" ]]; then
        # Validate the key against an authenticated endpoint
        if ! curl --fail --show-error --silent "$API_URL/schema" -H "X-API-Key: $1" >/dev/null 2>&1; then
            echo "Error: invalid API key or service unavailable"
            exit 1
        fi
        mkdir -p "$CONFIG_DIR"
        echo "$1" > "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"
        echo "вң“ API key saved. You're in."
        return
    fi

    echo "Log in to your account"
    echo ""
    read -p "Email: " email
    read -sp "Password: " password
    echo ""

    local resp
    if ! resp=$(curl --fail --show-error --silent "$API_URL/login" \
        -H "Content-Type: application/json" \
        -d "{\"email\":\"$(json_escape "$email")\",\"password\":\"$(json_escape "$password")\"}" 2>&1); then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        echo "Error: ${detail:-invalid email or password}"
        exit 1
    fi

    local key=$(echo "$resp" | grep -o '"api_key":"[^"]*"' | cut -d'"' -f4)
    if [[ -z "$key" ]]; then
        echo "Error: unexpected response"
        exit 1
    fi

    mkdir -p "$CONFIG_DIR"
    echo "$key" > "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    echo "вң“ Logged in. API key saved."
}

cmd_status() {
    read -p "Email: " email

    local resp
    if ! resp=$(curl --fail --show-error --silent "$API_URL/status" \
        -H "Content-Type: application/json" \
        -d "{\"email\":\"$(json_escape "$email")\"}" 2>&1); then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        echo "${detail:-Could not check status}"
        exit 1
    fi

    local status=$(echo "$resp" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

    case "$status" in
        approved)
            echo "вң“ Account approved."
            if [[ -f "$CONFIG_FILE" ]]; then
                echo "  API key is already saved. Run 'speaker query' to get started."
            else
                echo "  Run 'speaker login' to set your API key."
            fi
            ;;
        pending)
            echo "вҸі Account is still pending approval. Check back later."
            ;;
        *)
            echo "No account found for this email. Run 'speaker signup' to create one."
            ;;
    esac
}

cmd_logout() {
    rm -f "$CONFIG_FILE"
    echo "вң“ Logged out. API key removed."
}

cmd_query() {
    check_auth
    local key=$(get_key)
    local sql="$1"

    if [[ -z "$sql" ]]; then
        echo "Usage: speaker query \"SQL\""
        exit 1
    fi

    # Hint on first query of session
    local session_marker="$CONFIG_DIR/.session_$$"
    if [[ ! -f "$CONFIG_DIR/.session_hint" ]] || [[ $(find "$CONFIG_DIR/.session_hint" -mmin +60 2>/dev/null) ]]; then
        echo "рҹ’Ў Tip: Read ~/.speaker/SKILL.md вҖ” the mesh diagram + explore loop." >&2
        echo "" >&2
        touch "$CONFIG_DIR/.session_hint"
    fi

    local resp http_code
    if ! resp=$(curl --silent --show-error --location -w "\n%{http_code}" --max-time 60 "$API_URL/query" \
        -H "X-API-Key: $key" \
        -d "$sql" 2>&1); then
        echo "Error: query request failed: $resp" >&2
        exit 1
    fi

    http_code=$(echo "$resp" | tail -1)
    resp=$(echo "$resp" | sed '$d')

    if [[ "$http_code" != "200" ]]; then
        local detail=$(echo "$resp" | grep -o '"detail":"[^"]*"' | cut -d'"' -f4)
        if [[ "$http_code" == "429" ]]; then
            echo "Error: Rate limit hit. Wait a moment and try again." >&2
        elif [[ "$http_code" == "000" ]]; then
            echo "Error: Could not connect to server. Check your internet connection." >&2
        elif [[ -n "$detail" ]]; then
            echo "Error: $detail" >&2
        else
            echo "Error: query failed (HTTP $http_code)" >&2
        fi
        exit 1
    fi

    if [[ -z "$resp" ]] || [[ "$resp" == "" ]]; then
        echo "No results. Try DESCRIBE database.table to see columns." >&2
        return
    fi

    # Format output
    if [[ -t 1 ]]; then
        # Terminal: pretty print
        echo "$resp" | while IFS= read -r line; do
            echo "$line" | python3 -m json.tool 2>/dev/null || echo "$line"
        done
    else
        # Piped: raw JSON lines
        echo "$resp"
    fi
}

cmd_count() {
    local key resp count
    key=$(get_key)

    # Prefer the precise query if we're logged in.
    if [[ -n "$key" ]]; then
        if resp=$(curl --fail --show-error --silent "$API_URL/query" \
            -H "X-API-Key: $key" \
            -d "SELECT formatReadableQuantity(count()) as people FROM people.nucleus" 2>/dev/null); then
            count=$(echo "$resp" | grep -o '"people":"[^"]*"' | cut -d'"' -f4)
            if [[ -n "$count" ]]; then
                echo "$count"
                return
            fi
        fi
    fi

    # Works before signup/login and avoids relying on a stale health endpoint.
    echo "825M+"
}

cmd_schema() {
    local arg="$1"
    local path dst src first=1 refreshed=0

    ensure_schema_docs

    if [[ -z "$arg" ]]; then
        path="$SCHEMA_DIR/_mesh.yaml"
        if [[ ! -f "$path" ]]; then
            refresh_schema_docs_once refreshed
        fi
        if [[ ! -f "$path" ]]; then
            echo "Error: local schema file missing: $path" >&2
            echo "Run 'speaker update'." >&2
            exit 1
        fi
        cat "$path"
        return
    fi

    if [[ "$arg" == "--all" ]]; then
        while IFS='|' read -r dst src; do
            [[ -z "$dst" ]] && continue
            path="$SCHEMA_DIR/$dst"
            if [[ ! -f "$path" ]]; then
                refresh_schema_docs_once refreshed
            fi
            if [[ ! -f "$path" ]]; then
                echo "Error: local schema file missing: $path" >&2
                echo "Run 'speaker update'." >&2
                exit 1
            fi
            if [[ "$first" -eq 0 ]]; then
                printf '\n---\n'
            fi
            cat "$path"
            first=0
        done < <(schema_artifacts)
        return
    fi

    if ! path=$(schema_path_for "$arg"); then
        echo "Error: unknown table '$arg'" >&2
        echo "Run 'speaker schema' to see available tables." >&2
        exit 1
    fi

    if [[ ! -f "$path" ]]; then
        refresh_schema_docs_once refreshed
    fi
    if [[ ! -f "$path" ]]; then
        echo "Error: local schema file missing: $path" >&2
        echo "Run 'speaker update'." >&2
        exit 1
    fi

    cat "$path"
}

